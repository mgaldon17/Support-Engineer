# .env — secrets + machine-specific paths. Copy to `.env` and fill in real values.
#
# Two consumers (both read this file, never commit the real `.env` — only this template):
#   1. src/agentmem/config.py loads it BEFORE config.yaml, which references the API keys as
#      ${EMBEDDER_API_KEY} / ${LLM_API_KEY}. Relocate with AGENTMEM_DOTENV=/path/to/.env.
#   2. .mcp.json expands ${DC_MCP_HOME} from the environment when launching the `dc` MCP
#      server. Claude Code expands from the PROCESS env, so this value must be EXPORTED
#      before launching (the harness does not auto-source this file). Easiest:
#         set -a; source .env; set +a   # then start `claude`
# A real environment variable always overrides what is set here.

# Embedder API key — only needed for a remote OpenAI-compatible embedder
# (embedder.provider: openai/lmstudio). Empty for the default local huggingface embedder.
EMBEDDER_API_KEY=

# LLM API key — only exercised when llm.infer: true. "lm-studio" is the throwaway value
# LM Studio accepts; replace with a real key if you point llm.base_url at a hosted API.
LLM_API_KEY=lm-studio

# Path to the local Desktop Commander checkout that backs the `dc` MCP server in
# .mcp.json (the args/cwd resolve to ${DC_MCP_HOME}). Point it at your clone, e.g.
# `~/git/desktop-commander` (use an absolute path; ${VAR} in .mcp.json is not tilde-expanded).
DC_MCP_HOME=/path/to/desktop-commander
