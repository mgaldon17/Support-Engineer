# agentmem configuration — KEY=VALUE, loaded by src/agentmem/config.py.
#
# Precedence: a real environment variable always wins over a value set here, which in
# turn wins over the dataclass defaults in config.py. Point at a different file with
# AGENTMEM_CONFIG=/path/to/file. Lines starting with # are comments.
#
# The values below restate the built-in defaults, so editing them changes behaviour
# from one place. Secrets (API keys) live here too — gitignore this file if you put
# real ones in (a non-secret default is shipped).

# --- Qdrant / mem0 ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
MEM_COLLECTION=agentcore_lessons
# Namespace for mem0's identity filters; all lessons share it.
MEM_USER=agentcore

# --- Embedder ---
# Default is a LOCAL, in-process embedder (sentence-transformers via mem0's
# "huggingface" provider): no server, no API key, offline after the one-time download.
# For a remote OpenAI-compatible embedder set EMBEDDER_PROVIDER=openai (or lmstudio)
# plus EMBEDDER_MODEL / EMBEDDER_BASE_URL / EMBEDDER_API_KEY / EMBEDDER_DIMS.
EMBEDDER_PROVIDER=huggingface
EMBEDDER_MODEL=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDER_BASE_URL=
EMBEDDER_API_KEY=
# MUST match the model's output dim (384 for the default MiniLM, 768 nomic, 1536 for
# OpenAI text-embedding-3). Changing it requires a fresh Qdrant collection.
EMBEDDER_DIMS=384

# --- LLM stub (mem0 builds one even with infer=False; never actually called) ---
LLM_MODEL=qwen2.5-7b-instruct-1m
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=lm-studio

# --- Guardrails ---
# Comma-separated host allowlist for browser navigation; empty = allow any host.
GUARD_ALLOW_DOMAINS=
GUARD_CHECK_REACHABLE=true
# URL-reachability probe (UrlGuardrail).
PROBE_TIMEOUT=5.0
PROBE_USER_AGENT=Mozilla/5.0 (agentmem url-guardrail)

# --- Retrieval ---
LESSON_SEARCH_LIMIT=8
LESSON_LIST_LIMIT=1000
