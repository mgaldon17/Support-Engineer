{
  "mcpServers": {
    "memory": {
      "command": "python",
      "args": ["-m", "agentmem.mcp_server"],
      "env": {
        "PYTHONPATH": "src"
      }
    },
    "pw": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    },
    "dc": {
      "command": "node",
      "args": ["${DC_MCP_HOME}/dist/index.js"],
      "cwd": "${DC_MCP_HOME}"
    }
  }
}
